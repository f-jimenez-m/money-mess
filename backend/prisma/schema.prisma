// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS AND AUTHENTICATION
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  passwordHash String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accounts       Account[]
  categories     Category[]
  transactions   Transaction[]
  recurringRules RecurringRule[]

  @@map("users")
}

// ============================================
// ACCOUNTS (Money containers)
// ============================================

model Account {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      AccountType
  currency  String   @default("USD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  recurringRules RecurringRule[]

  @@unique([userId, name])
  @@index([userId])
  @@map("accounts")
}

enum AccountType {
  CASH
  BANK
  CREDIT
  SAVINGS
}

// ============================================
// CATEGORIES (Income/Expense classification)
// ============================================

model Category {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      CategoryType
  color     String   @default("#6B7280")
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  recurringRules RecurringRule[]

  @@unique([userId, name, type])
  @@index([userId, type])
  @@map("categories")
}

enum CategoryType {
  INCOME
  EXPENSE
}

// ============================================
// RECURRING RULES (Rules for recurring transactions)
// ============================================

model RecurringRule {
  id                 String   @id @default(cuid())
  userId             String
  name               String
  type               TransactionType
  amount             Decimal
  frequency          Frequency
  startDate          DateTime
  endDate            DateTime?
  dayOfMonth         Int?
  accountId          String
  categoryId         String?
  installmentsTotal  Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  account      Account       @relation(fields: [accountId], references: [id], onDelete: Restrict)
  category     Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  transactions Transaction[]

  @@index([userId])
  @@index([accountId])
  @@map("recurring_rules")
}

enum Frequency {
  WEEKLY
  MONTHLY
  YEARLY
}

// ============================================
// TRANSACTIONS (Core ledger)
// ============================================

model Transaction {
  id               String   @id @default(cuid())
  userId           String
  accountId        String
  categoryId       String?
  type             TransactionType
  amount           Decimal
  description      String
  dueDate          DateTime
  paidDate         DateTime?
  status           TransactionStatus @default(PENDING)
  
  // For installments (cuotas)
  installmentNumber  Int?
  installmentTotal   Int?
  
  // For transfers between accounts
  transferGroupId    String?
  relatedTransactionId String? @unique
  
  // For recurring transactions
  recurringRuleId    String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  account          Account       @relation(fields: [accountId], references: [id], onDelete: Restrict)
  category         Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  recurringRule    RecurringRule? @relation(fields: [recurringRuleId], references: [id], onDelete: SetNull)
  
  // Self-relation for transfer pairs (one-to-one bidirectional)
  relatedTransaction Transaction? @relation("TransferPair", fields: [relatedTransactionId], references: [id], onDelete: SetNull)
  relatedTransactionReverse Transaction? @relation("TransferPair")

  @@index([userId])
  @@index([accountId])
  @@index([categoryId])
  @@index([status])
  @@index([dueDate])
  @@index([paidDate])
  @@index([recurringRuleId])
  @@index([transferGroupId])
  @@index([userId, dueDate])
  @@index([userId, accountId, dueDate])
  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum TransactionStatus {
  PENDING
  PAID
}
