# ============================================
# PRODUCTION ENVIRONMENT (Render.com)
# ============================================

# Database (PostgreSQL - will be provided by Render)
# Example from Render: postgresql://user:pass@dpg-xxx.render-instances.com:5432/dbname
DATABASE_URL="postgresql://user:password@your-render-db-host:5432/moneymess"

# Server Configuration
NODE_ENV="production"
PORT=3000
HOST="0.0.0.0"

# JWT Secret (CHANGE THIS IN PRODUCTION)
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-super-secret-key-generate-a-random-one"
JWT_EXPIRES_IN="7d"

# CORS Origin (adjust to your frontend URL)
# Example: https://your-frontend.vercel.app
CORS_ORIGIN="https://your-frontend-domain.com"

# Logging
LOG_LEVEL="info"
