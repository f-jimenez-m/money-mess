# Local Development Environment
# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/moneymess"

# Server
NODE_ENV="development"
PORT=3000
HOST="0.0.0.0"

# JWT
JWT_SECRET="dev-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"

# CORS
CORS_ORIGIN="http://localhost:5173"

# Logging
LOG_LEVEL="debug"
